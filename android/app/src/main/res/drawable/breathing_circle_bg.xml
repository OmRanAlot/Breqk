<?xml version="1.0" encoding="utf-8"?>
<!--
    breathing_circle_bg.xml
    Oval stroke drawable used as the background for the delay overlay's central circle.
    ObjectAnimator in AppUsageMonitor scales the parent view (scaleX/scaleY 1.0→1.05→1.0)
    to produce the "breathing" pulse effect matching stitch_screens/7_overlay.html:
      animation: breathing 3s ease-in-out infinite
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <!-- Transparent fill — circle is hollow, content shows through -->
    <solid android:color="#00000000" />
    <!-- White border at ~40% opacity, matching CSS border-color: rgba(255,255,255,0.4) -->
    <stroke
        android:width="1dp"
        android:color="#66FFFFFF" />
</shape>
