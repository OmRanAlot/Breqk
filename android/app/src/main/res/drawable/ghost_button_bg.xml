<?xml version="1.0" encoding="utf-8"?>
<!--
    ghost_button_bg.xml
    Ghost / outline pill used for the disabled "Continue (Wait Xs)" button on the delay overlay.
    Matches stitch_screens/7_overlay.html secondary button:
      bg-white/10 border border-white/20 text-white/60 rounded-full
    AppUsageMonitor.startContinueCountdown() enables the button after the countdown, changing
    textColor to fully white to indicate it is now tappable.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- ~10% white fill (bg-white/10) -->
    <solid android:color="#1AFFFFFF" />
    <!-- ~20% white border (border-white/20) -->
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
    <corners android:radius="9999dp" />
</shape>
