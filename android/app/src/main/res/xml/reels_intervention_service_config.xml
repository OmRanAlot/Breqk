<?xml version="1.0" encoding="utf-8"?>
<!-- reels_intervention_service_config.xml
     Config for ReelsInterventionService.
     Primarily watches Instagram and YouTube for scroll/reels detection.
     packageNames is intentionally OMITTED so that TYPE_WINDOW_STATE_CHANGED events
     from other apps (e.g., the launcher) can be received — this lets the service
     detect when the user leaves Instagram/YouTube via Home button or app switcher,
     preventing false-positive budget accumulation on the home screen.
     The Java code in onAccessibilityEvent() filters non-target packages efficiently.
     typeViewScrolled required for scroll counting.
     flagReportViewIds required for findAccessibilityNodeInfosByViewId to return results.
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeViewScrolled|typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:description="@string/app_name"
    android:notificationTimeout="100"
    android:settingsActivity="" />
