<?xml version="1.0" encoding="utf-8"?>
<!--
    widget_breqk.xml — Home screen widget layout
    ===================================================
    PURPOSE: Displays the app name and two tappable icons (Instagram, YouTube).
    Tapping an icon opens the distraction-free in-app browser for that platform.
    Tapping the app title opens the main Breqk app.

    DESIGN SYSTEM:
      - Background: #1D201F (dark bg from design/tokens.ts)
      - Text:       #F1FFE7 (light green primary text)
      - Accent:     #5B9A8B (Sage Teal — used for icon tints)

    REMOTEVIEWS CONSTRAINTS (Android widgets):
      - Only basic views allowed: LinearLayout, FrameLayout, TextView, ImageView, etc.
      - NO custom views, NO ?android:attr/selectableItemBackground, NO RecyclerView
      - Click handlers are set via PendingIntent in BreqkWidgetProvider.java

    REFERENCED BY:
      - widget_breqk_info.xml  (android:initialLayout points here)
      - BreqkWidgetProvider.java (inflates this layout via RemoteViews)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1D201F"
    android:padding="16dp"
    android:gravity="center">

    <!--
        App title — tapping this opens the main Breqk app.
        Click handler set in BreqkWidgetProvider.java via PendingIntent.
    -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#F1FFE7"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="12dp" />

    <!--
        Icon row — holds the Instagram and YouTube quick-launch buttons.
        Each icon opens the distraction-free browser (BrowserScreen.js) for that platform.
        Icons are vector drawables (ic_instagram.xml, ic_youtube.xml) in Sage Teal.
    -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!--
            Instagram icon button.
            Deep links to: breqk://browser/instagram
            Which React Navigation routes to: BrowserScreen with platform='instagram'
            Click handler: PendingIntent set in BreqkWidgetProvider.java (request code 1)
            Icon source: res/drawable/ic_instagram.xml (teal camera outline)
        -->
        <ImageView
            android:id="@+id/widget_btn_instagram"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_instagram"
            android:contentDescription="Open distraction-free Instagram"
            android:padding="6dp"
            android:layout_marginEnd="24dp" />

        <!--
            YouTube icon button.
            Deep links to: breqk://browser/youtube
            Which React Navigation routes to: BrowserScreen with platform='youtube'
            Click handler: PendingIntent set in BreqkWidgetProvider.java (request code 2)
            Icon source: res/drawable/ic_youtube.xml (teal play button)
        -->
        <ImageView
            android:id="@+id/widget_btn_youtube"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_youtube"
            android:contentDescription="Open distraction-free YouTube"
            android:padding="6dp" />
    </LinearLayout>
</LinearLayout>
