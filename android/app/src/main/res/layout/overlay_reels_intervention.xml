<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_reels_intervention.xml
    Centered intervention popup shown when user scrolls through Reels (Instagram)
    or Shorts (YouTube) beyond the configured threshold.

    Displayed by ReelsInterventionService.triggerIntervention() via WindowManager
    using TYPE_ACCESSIBILITY_OVERLAY (no SYSTEM_ALERT_WINDOW permission needed).

    Layout structure:
      FrameLayout (root, match_parent x match_parent, transparent)
      Inner LinearLayout (the visible card, centered via layout_gravity="center")

    Why FrameLayout wrapper?
      WindowManager overlays ignore margins on the root view. To get a centered card
      with side padding, we need a full-screen transparent FrameLayout as the root,
      with the card inside it using layout_gravity="center" and layout_margin for
      the horizontal breathing room. Same pattern as delay_overlay.xml.

    WindowManager params set in triggerIntervention():
      width=MATCH_PARENT, height=MATCH_PARENT fills the screen.
      gravity=Gravity.CENTER, FLAG_NOT_TOUCH_MODAL passes outside touches through.

    Design language: dark navy card (#1A1B41), mint/seafoam text (#F1FFE7),
    matches delay_overlay.xml and the app design tokens.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Visible card — centered on screen with 24dp horizontal margins -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:background="@drawable/rounded_card_background"
        android:padding="24dp"
        android:gravity="center"
        android:elevation="8dp">

        <!-- Eye emoji — grabs attention without being alarming -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👀"
            android:textSize="40sp"
            android:layout_marginBottom="12dp" />

        <!-- Main title -->
        <TextView
            android:id="@+id/intervention_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Still here intentionally?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#F1FFE7"
            android:textAlignment="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle — platform-specific text set in code:
             "You've scrolled through N Reels." or "...N Shorts." -->
        <TextView
            android:id="@+id/intervention_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="You've scrolled through a few Reels."
            android:textSize="14sp"
            android:textColor="#99F1FFE7"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- "Lock In" — deep-links to Instagram home feed, resets counter to 0 -->
        <Button
            android:id="@+id/btn_lock_in"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔒 Lock In"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF"
            android:textColor="#000000"
            android:layout_marginBottom="10dp" />

        <!-- "Take a Break" — fires GLOBAL_ACTION_BACK to exit Reels entirely -->
        <Button
            android:id="@+id/btn_take_break"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Take a Break"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#2A2A2A"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</FrameLayout>
