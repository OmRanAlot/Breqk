<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_reels_intervention.xml
    ─────────────────────────────────────────────────────────────────────────────
    Bottom-sheet overlay shown by ReelsInterventionService.triggerIntervention()
    when the user scrolls past the Reels/Shorts threshold.
    Design matches stitch_screens/3_reels_intervention.jpg.

    Layout structure:
      FrameLayout (root, match_parent × match_parent, ~75% opaque dark backdrop)
        └─ LinearLayout (bottom sheet — dark, rounded top corners, bottom-aligned)
             ├─ View (grab handle pill — decorative)
             ├─ TextView "Reels Detected"
             ├─ Button "Return to Feed" (primary white pill)
             └─ Button "Force Close Instagram" (secondary outline pill)

    WindowManager params set in ReelsInterventionService.triggerIntervention():
      TYPE_ACCESSIBILITY_OVERLAY — no SYSTEM_ALERT_WINDOW needed for AccessibilityServices
      width=MATCH_PARENT, height=MATCH_PARENT
      Gravity.BOTTOM — sheet rises from the bottom edge of the screen

    View IDs used by ReelsInterventionService.java:
      intervention_title — "Reels Detected" headline (text set in code to "Reels Detected")
      btn_lock_in        — "Return to Feed" → deep-link to instagram://feed or youtube://
      btn_take_break     — "Force Close" → fires GLOBAL_ACTION_HOME
                           (text updated in code to include the app name)
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BF000000">

    <!-- ── Bottom sheet card ──────────────────────────────────────────────────── -->
    <!--
        layout_gravity="bottom" anchors the sheet to the bottom of the FrameLayout.
        bottom_sheet_bg provides the dark background with rounded top corners (32dp).
        paddingBottom=48dp gives breathing room above the system nav bar.
    -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_bg"
        android:paddingTop="12dp"
        android:paddingBottom="48dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Grab handle pill — decorative signal that sheet is interactive -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@drawable/grab_handle"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp" />

        <!--
            intervention_title: "Reels Detected" headline.
            Text is set in triggerIntervention() — could be "Reels Detected" or "Shorts Detected".
            24sp, semibold, ~90% white.
        -->
        <TextView
            android:id="@+id/intervention_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reels Detected"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E6FFFFFF"
            android:layout_marginBottom="32dp" />

        <!--
            btn_lock_in: "Return to Feed" (primary white pill)
            onClick: dismiss overlay, deep-link to instagram://feed (or youtube://).
            Previously "Lock In" (fires GLOBAL_ACTION_HOME) — roles have swapped.
        -->
        <Button
            android:id="@+id/btn_lock_in"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Return to Feed"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="14dp" />

        <!--
            btn_take_break: "Force Close Instagram" (secondary outline pill)
            Text is updated in triggerIntervention() to include the specific app name.
            onClick: dismiss overlay, fire GLOBAL_ACTION_HOME → exit to Android home screen.
            Previously "Take a Break" (deep-links to feed) — roles have swapped.
        -->
        <Button
            android:id="@+id/btn_take_break"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Force Close Instagram"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/outline_pill_button_bg" />

    </LinearLayout>

</FrameLayout>
