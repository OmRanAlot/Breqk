<?xml version="1.0" encoding="utf-8"?>
<!--
    delay_overlay.xml
    ─────────────────────────────────────────────────────────────────────────────
    Full-screen native overlay shown by AppUsageMonitor.showDelayOverlay() when a
    blocked app is foregrounded.

    Design: pure black background, large static message centered, a single ring
    that pulses outward (scale + alpha ripple) around the text, two buttons at bottom.

    Layout structure:
      FrameLayout (root, match_parent × match_parent, solid black)
        ├─ FrameLayout (center section, fills screen, gravity=center)
        │    ├─ View (pulse_ring — animated via ObjectAnimator: scale 1.0→1.8, alpha 0.5→0)
        │    └─ TextView (title — static, "Is this intentional?", white, centered)
        └─ LinearLayout (bottom section, gravity=bottom — two action buttons)

    View IDs used by AppUsageMonitor.java:
      pulse_ring    — View behind text, animated via ObjectAnimator (scale + alpha ripple)
      title         — Static question text; overridden by customMessage if set
      backButton    — "Back to Reality" — dismisses overlay, fires ACTION_MAIN/HOME
      continueButton — "Continue (Wait Xs)" — enabled after startContinueCountdown()
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ── Center section: pulse ring behind static text ──────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center">

        <!--
            pulse_ring: circle border that expands outward and fades.
            ObjectAnimator in AppUsageMonitor.startRippleAnimation() animates:
              scaleX/scaleY: 1.0 → 1.8  (ring expands from text size outward)
              alpha:         0.5 → 0.0  (fades as it expands)
            Duration 2000ms, INFINITE RESTART. Since alpha ends at 0, the instant
            reset to scale=1.0/alpha=0.5 is invisible — no visible jump.
            Size 180dp matches the approximate bounding box of the question text.
        -->
        <View
            android:id="@+id/pulse_ring"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/breathing_circle_bg"
            android:alpha="0.5" />

        <!--
            title: static question text, centered on screen.
            Font: regular weight (not bold), 28sp, pure white. Generous horizontal padding
            so text wraps cleanly within the ring bounds.
            Text is overridden in showDelayOverlay() with customMessage if the user set one.
        -->
        <TextView
            android:id="@+id/title"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Is this intentional?"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.35" />
    </FrameLayout>

    <!-- ── Bottom action buttons ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="64dp">

        <!--
            backButton: "Back to Reality" (primary)
            White pill, black text. Dismisses overlay, sends user to Android home screen.
        -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Back to Reality"
            android:textSize="18sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:background="@drawable/white_pill_button_bg"
            android:layout_marginBottom="14dp" />

        <!--
            continueButton: "Continue (Wait Xs)" (ghost, secondary)
            Disabled initially. startContinueCountdown() ticks the label down and enables
            this button once the countdown reaches zero.
        -->
        <Button
            android:id="@+id/continueButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Continue (Wait 3s)"
            android:textSize="14sp"
            android:textColor="#99FFFFFF"
            android:background="@drawable/ghost_button_bg"
            android:enabled="false" />
    </LinearLayout>

</FrameLayout>
